# ===========================================
# Briefed POC — Environment Variables
# ===========================================
#
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. Never paste real values in this file.

# ---------- Supabase ----------
# Project URL — from Supabase dashboard, Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://mpndtkpjmdvrcjsltmaw.supabase.co

# Anon (publishable) key — safe to expose to the browser
# From Supabase dashboard, Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SECRET. Bypasses RLS. Server-side only.
# From Supabase dashboard, Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Clerk ----------
# Wired in spec v2; placeholders for now.
# From Clerk dashboard, API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk-hosted sign-in / sign-up paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---------- Anthropic ----------
# Used in week 4 for tax-return extraction.
# From console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# ---------- Plaid (week 3) ----------
# Placeholders. Populate when Plaid sandbox account is created.
PLAID_CLIENT_ID=
PLAID_SECRET_SANDBOX=
PLAID_ENV=sandbox

# ---------- Pinwheel (week 6) ----------
# Placeholders.
PINWHEEL_API_KEY_SANDBOX=
PINWHEEL_ENV=sandbox

# ---------- App config ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true
